---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="contacto" class="relative py-28 overflow-hidden">

  <!-- =============================================
       BACKGROUND DECORATIONS
  ============================================= -->
  <div class="absolute inset-0 pointer-events-none select-none" aria-hidden="true">

    <!-- Treble clef faint right -->
    <svg class="absolute -right-6 top-1/2 -translate-y-1/2 w-45 opacity-[0.04] dark:opacity-[0.06]" viewBox="0 0 200 400" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M120 20 C160 20, 180 60, 180 100 C180 160, 120 180, 80 200 C40 220, 20 260, 40 300 C60 340, 120 340, 140 300 C160 260, 140 220, 100 200 L100 360 C100 380, 80 390, 60 380" stroke="#C85A1A" stroke-width="8" stroke-linecap="round" fill="none"/>
      <circle cx="80" cy="370" r="20" stroke="#C85A1A" stroke-width="8" fill="none"/>
    </svg>

    <!-- Tropical leaf bottom left -->
    <svg class="absolute -bottom-12 -left-12 w-60 opacity-[0.05] dark:opacity-[0.07]" viewBox="0 0 240 280" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M200 10 C140 55, 50 145, 15 270 C70 210, 165 120, 200 10Z" fill="#1A7A4A"/>
      <path d="M200 10 C140 65, 55 160, 15 270" stroke="#1A7A4A" stroke-width="2"/>
    </svg>

  </div>

  <div class="max-w-6xl mx-auto px-6 relative z-10">

    <!-- Section header -->
    <div class="text-center mb-20">
      <div class="flex items-center justify-center gap-3 mb-4">
        <span class="block w-6 h-0.5 bg-brand-orange"></span>
        <span class="text-xs font-semibold tracking-[0.15em] uppercase text-brand-orange">
          {lang === 'es' ? 'Hablemos' : 'Get in touch'}
        </span>
        <span class="block w-6 h-0.5 bg-brand-orange"></span>
      </div>
      <h2 class="font-display font-bold text-4xl md:text-5xl text-warm-text dark:text-neutral-100 mb-5">
        {t('contact.title')}
      </h2>
      <p class="text-lg text-warm-muted dark:text-neutral-400 max-w-lg mx-auto leading-relaxed">
        {t('contact.subtitle')}
      </p>
    </div>

    <!-- Two column layout: contact info left, form right -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

      <!-- LEFT: Contact details -->
      <div class="flex flex-col gap-8">

        <!-- Contact info cards -->
        <div class="flex flex-col gap-4">

          <!-- Email -->
          <div class="flex items-center gap-5 p-5 bg-warm-card dark:bg-neutral-900 border border-warm-border dark:border-neutral-800 rounded-2xl hover:border-brand-orange dark:hover:border-brand-orange transition-colors duration-200 group">
            <div class="w-11 h-11 rounded-xl bg-brand-orange/10 dark:bg-brand-orange/20 flex items-center justify-center shrink-0 group-hover:bg-brand-orange/20 dark:group-hover:bg-brand-orange/30 transition-colors">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#C85A1A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-wider text-warm-muted dark:text-neutral-500 mb-0.5">
                {t('contact.email_label')}
              </p>
              <a
                href="mailto:info@fundacionpiponavarro.org"
                class="text-sm font-medium text-warm-text dark:text-neutral-300 hover:text-brand-orange transition-colors"
              >
                info@fundacionpiponavarro.org
              </a>
            </div>
          </div>

          <!-- Phone -->
          <div class="flex items-center gap-5 p-5 bg-warm-card dark:bg-neutral-900 border border-warm-border dark:border-neutral-800 rounded-2xl hover:border-brand-green dark:hover:border-brand-green transition-colors duration-200 group">
            <div class="w-11 h-11 rounded-xl bg-brand-green/10 dark:bg-brand-green/20 flex items-center justify-center shrink-0 group-hover:bg-brand-green/20 dark:group-hover:bg-brand-green/30 transition-colors">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1A7A4A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 6 6l1.27-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-wider text-warm-muted dark:text-neutral-500 mb-0.5">
                {t('contact.phone_label')}
              </p>
              <a
                href="tel:+50760000000"
                class="text-sm font-medium text-warm-text dark:text-neutral-300 hover:text-brand-green transition-colors"
              >
                +507 6000-0000
              </a>
            </div>
          </div>

          <!-- Location -->
          <div class="flex items-center gap-5 p-5 bg-warm-card dark:bg-neutral-900 border border-warm-border dark:border-neutral-800 rounded-2xl hover:border-brand-gold dark:hover:border-brand-gold transition-colors duration-200 group">
            <div class="w-11 h-11 rounded-xl bg-brand-gold/10 dark:bg-brand-gold/20 flex items-center justify-center shrink-0 group-hover:bg-brand-gold/20 dark:group-hover:bg-brand-gold/30 transition-colors">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#E8B84B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-wider text-warm-muted dark:text-neutral-500 mb-0.5">
                {t('contact.address_label')}
              </p>
              <p class="text-sm font-medium text-warm-text dark:text-neutral-300">
                {t('contact.address_value')}
              </p>
            </div>
          </div>

        </div>

        <!-- Social links -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-warm-muted dark:text-neutral-500 mb-4">
            {t('contact.follow')}
          </p>
          <div class="flex items-center gap-3">

            <!-- Facebook -->
            <a
              href="#"
              aria-label="Facebook"
              class="w-10 h-10 rounded-xl border border-warm-border dark:border-neutral-800 bg-warm-card dark:bg-neutral-900 flex items-center justify-center text-warm-muted hover:text-brand-orange hover:border-brand-orange dark:hover:border-brand-orange transition-colors duration-200"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
            </a>

            <!-- Instagram -->
            <a
              href="#"
              aria-label="Instagram"
              class="w-10 h-10 rounded-xl border border-warm-border dark:border-neutral-800 bg-warm-card dark:bg-neutral-900 flex items-center justify-center text-warm-muted hover:text-brand-orange hover:border-brand-orange dark:hover:border-brand-orange transition-colors duration-200"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="2" width="20" height="20" rx="5"/>
                <circle cx="12" cy="12" r="4"/>
                <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
              </svg>
            </a>

            <!-- YouTube -->
            <a
              href="#"
              aria-label="YouTube"
              class="w-10 h-10 rounded-xl border border-warm-border dark:border-neutral-800 bg-warm-card dark:bg-neutral-900 flex items-center justify-center text-warm-muted hover:text-brand-orange hover:border-brand-orange dark:hover:border-brand-orange transition-colors duration-200"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/>
                <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="white"/>
              </svg>
            </a>

          </div>
        </div>

      </div>

      <!-- RIGHT: Contact form -->
      <!-- Note: this form needs a backend or service like Formspree/Netlify Forms
           to actually send emails. The action URL is a placeholder.
           To wire it up later: replace action="#" with your Formspree endpoint. -->
      <div class="bg-warm-card dark:bg-neutral-900 border border-warm-border dark:border-neutral-800 rounded-3xl p-8 md:p-10">

        <h3 class="font-display font-bold text-2xl text-warm-text dark:text-neutral-100 mb-2">
          {lang === 'es' ? 'Envíanos un mensaje' : 'Send us a message'}
        </h3>
        <p class="text-sm text-warm-muted dark:text-neutral-500 mb-8">
          {lang === 'es'
            ? 'Te responderemos a la brevedad posible.'
            : 'We will get back to you as soon as possible.'}
        </p>

        <form
          id="contact-form"
          action="#"
          method="POST"
          class="flex flex-col gap-5"
          novalidate
        >

          <!-- Name -->
          <div class="flex flex-col gap-1.5">
            <label for="name" class="text-xs font-semibold uppercase tracking-wider text-warm-muted dark:text-neutral-400">
              {lang === 'es' ? 'Nombre' : 'Name'}
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder={lang === 'es' ? 'Tu nombre completo' : 'Your full name'}
              class="w-full px-4 py-3 rounded-xl border border-warm-border dark:border-neutral-700 bg-warm-white dark:bg-neutral-800 text-warm-text dark:text-neutral-100 placeholder-warm-muted dark:placeholder-neutral-600 text-sm focus:outline-none focus:border-brand-orange dark:focus:border-brand-orange transition-colors"
            />
          </div>

          <!-- Email -->
          <div class="flex flex-col gap-1.5">
            <label for="email" class="text-xs font-semibold uppercase tracking-wider text-warm-muted dark:text-neutral-400">
              {lang === 'es' ? 'Correo electrónico' : 'Email'}
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder={lang === 'es' ? 'tu@correo.com' : 'your@email.com'}
              class="w-full px-4 py-3 rounded-xl border border-warm-border dark:border-neutral-700 bg-warm-white dark:bg-neutral-800 text-warm-text dark:text-neutral-100 placeholder-warm-muted dark:placeholder-neutral-600 text-sm focus:outline-none focus:border-brand-orange dark:focus:border-brand-orange transition-colors"
            />
          </div>

          <!-- Subject -->
          <div class="flex flex-col gap-1.5">
            <label for="subject" class="text-xs font-semibold uppercase tracking-wider text-warm-muted dark:text-neutral-400">
              {lang === 'es' ? 'Asunto' : 'Subject'}
            </label>
            <select
              id="subject"
              name="subject"
              class="w-full px-4 py-3 rounded-xl border border-warm-border dark:border-neutral-700 bg-warm-white dark:bg-neutral-800 text-warm-text dark:text-neutral-100 text-sm focus:outline-none focus:border-brand-orange dark:focus:border-brand-orange transition-colors appearance-none cursor-pointer"
            >
              <option value="donacion">
                {lang === 'es' ? 'Quiero donar un instrumento' : 'I want to donate an instrument'}
              </option>
              <option value="evento">
                {lang === 'es' ? 'Información sobre eventos' : 'Event information'}
              </option>
              <option value="voluntario">
                {lang === 'es' ? 'Quiero ser voluntario' : 'I want to volunteer'}
              </option>
              <option value="otro">
                {lang === 'es' ? 'Otro' : 'Other'}
              </option>
            </select>
          </div>

          <!-- Message -->
          <div class="flex flex-col gap-1.5">
            <label for="message" class="text-xs font-semibold uppercase tracking-wider text-warm-muted dark:text-neutral-400">
              {lang === 'es' ? 'Mensaje' : 'Message'}
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="4"
              placeholder={lang === 'es' ? 'Cuéntanos cómo quieres ayudar...' : 'Tell us how you want to help...'}
              class="w-full px-4 py-3 rounded-xl border border-warm-border dark:border-neutral-700 bg-warm-white dark:bg-neutral-800 text-warm-text dark:text-neutral-100 placeholder-warm-muted dark:placeholder-neutral-600 text-sm focus:outline-none focus:border-brand-orange dark:focus:border-brand-orange transition-colors resize-none"
            ></textarea>
          </div>

          <!-- Submit -->
          <button
            type="submit"
            class="w-full flex items-center justify-center gap-2 px-6 py-3.5 rounded-xl bg-brand-orange text-white text-sm font-semibold hover:-translate-y-0.5 hover:shadow-lg hover:shadow-brand-orange/25 transition-all duration-150 mt-2"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
            </svg>
            {lang === 'es' ? 'Enviar mensaje' : 'Send message'}
          </button>

          <!-- Success / error feedback (shown via JS) -->
          <p id="form-feedback" class="hidden text-center text-sm font-medium rounded-xl py-3 px-4"></p>

        </form>

      </div>
    </div>
  </div>

</section>

<script>
  // =============================================
  // CONTACT FORM — client-side feedback only.
  // To wire real email sending, replace the form
  // action with a Formspree or similar endpoint
  // and remove this preventDefault block.
  // =============================================
  const form     = document.getElementById('contact-form') as HTMLFormElement;
  const feedback = document.getElementById('form-feedback') as HTMLElement;
  const lang     = document.documentElement.lang ?? 'es';

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    const name    = (form.querySelector('#name')    as HTMLInputElement).value.trim();
    const email   = (form.querySelector('#email')   as HTMLInputElement).value.trim();
    const message = (form.querySelector('#message') as HTMLTextAreaElement).value.trim();

    // Basic client-side validation
    if (!name || !email || !message) {
      feedback.textContent = lang === 'en'
        ? 'Please fill in all required fields.'
        : 'Por favor completa todos los campos requeridos.';
      feedback.className = 'text-center text-sm font-medium rounded-xl py-3 px-4 bg-brand-red/10 text-brand-red';
      return;
    }

    // Placeholder success response.
    // Replace this block with actual fetch() to your form endpoint.
    feedback.textContent = lang === 'en'
      ? '✓ Message sent! We will be in touch soon.'
      : '✓ ¡Mensaje enviado! Te responderemos pronto.';
    feedback.className = 'text-center text-sm font-medium rounded-xl py-3 px-4 bg-brand-green/10 text-brand-green';
    form.reset();
  });
</script>
