---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="bg-neutral-900 dark:bg-black text-neutral-400 py-16 relative overflow-hidden">

  <!-- Faint waveform decoration -->
  <div class="absolute inset-0 pointer-events-none select-none opacity-[0.03]" aria-hidden="true">
    <svg class="absolute bottom-0 left-0 w-full" viewBox="0 0 1200 120" preserveAspectRatio="none" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="50"  y="20" width="20" height="100" rx="10" fill="#C85A1A"/>
      <rect x="100" y="10" width="20" height="110" rx="10" fill="#E8B84B"/>
      <rect x="150" y="40" width="20" height="80"  rx="10" fill="#C85A1A"/>
      <rect x="200" y="5"  width="20" height="115" rx="10" fill="#E8B84B"/>
      <rect x="250" y="30" width="20" height="90"  rx="10" fill="#1A7A4A"/>
      <rect x="300" y="15" width="20" height="105" rx="10" fill="#C85A1A"/>
      <rect x="350" y="45" width="20" height="75"  rx="10" fill="#E8B84B"/>
      <rect x="400" y="0"  width="20" height="120" rx="10" fill="#D94F3D"/>
      <rect x="450" y="25" width="20" height="95"  rx="10" fill="#C85A1A"/>
      <rect x="500" y="50" width="20" height="70"  rx="10" fill="#1A7A4A"/>
      <rect x="550" y="10" width="20" height="110" rx="10" fill="#E8B84B"/>
      <rect x="600" y="35" width="20" height="85"  rx="10" fill="#C85A1A"/>
      <rect x="650" y="20" width="20" height="100" rx="10" fill="#D94F3D"/>
      <rect x="700" y="5"  width="20" height="115" rx="10" fill="#E8B84B"/>
      <rect x="750" y="40" width="20" height="80"  rx="10" fill="#1A7A4A"/>
      <rect x="800" y="15" width="20" height="105" rx="10" fill="#C85A1A"/>
      <rect x="850" y="30" width="20" height="90"  rx="10" fill="#E8B84B"/>
      <rect x="900" y="0"  width="20" height="120" rx="10" fill="#D94F3D"/>
      <rect x="950" y="45" width="20" height="75"  rx="10" fill="#C85A1A"/>
      <rect x="1000" y="20" width="20" height="100" rx="10" fill="#1A7A4A"/>
      <rect x="1050" y="10" width="20" height="110" rx="10" fill="#E8B84B"/>
      <rect x="1100" y="35" width="20" height="85"  rx="10" fill="#C85A1A"/>
      <rect x="1150" y="55" width="20" height="65"  rx="10" fill="#D94F3D"/>
    </svg>
  </div>

  <div class="max-w-6xl mx-auto px-6 relative z-10">

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 pb-12 border-b border-neutral-800">

      <!-- Brand column -->
      <div class="flex flex-col gap-4">
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-lg bg-brand-orange flex items-center justify-center shrink-0">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M9 18V5l12-2v13" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="6" cy="18" r="3" stroke="white" stroke-width="2"/>
              <circle cx="18" cy="16" r="3" stroke="white" stroke-width="2"/>
            </svg>
          </div>
          <span class="font-display font-bold text-white text-base">
            Fundación Pipo Navarro
          </span>
        </div>
        <p class="text-sm leading-relaxed text-neutral-500">
          {t('footer.tagline')}
        </p>
        <!-- Panama flag colors accent bar -->
        <div class="flex gap-1 mt-1">
          <div class="h-1 w-8 rounded-full bg-red-500 opacity-60"></div>
          <div class="h-1 w-8 rounded-full bg-blue-500 opacity-60"></div>
          <div class="h-1 w-8 rounded-full bg-white opacity-30"></div>
        </div>
      </div>

      <!-- Quick links column -->
      <div class="flex flex-col gap-4">
        <h4 class="text-xs font-semibold uppercase tracking-[0.15em] text-neutral-500">
          {lang === 'es' ? 'Navegación' : 'Navigation'}
        </h4>
        <nav class="flex flex-col gap-2.5">
          <a href="#mision"   class="text-sm text-neutral-400 hover:text-brand-orange transition-colors">{t('nav.mission')}</a>
          <a href="#donar"    class="text-sm text-neutral-400 hover:text-brand-orange transition-colors">{t('nav.donate')}</a>
          <a href="#eventos"  class="text-sm text-neutral-400 hover:text-brand-orange transition-colors">{t('nav.events')}</a>
          <a href="#galeria"  class="text-sm text-neutral-400 hover:text-brand-orange transition-colors">{t('nav.gallery')}</a>
          <a href="#contacto" class="text-sm text-neutral-400 hover:text-brand-orange transition-colors">{t('nav.contact')}</a>
        </nav>
      </div>

      <!-- Contact column -->
      <div class="flex flex-col gap-4">
        <h4 class="text-xs font-semibold uppercase tracking-[0.15em] text-neutral-500">
          {lang === 'es' ? 'Contacto' : 'Contact'}
        </h4>
        <div class="flex flex-col gap-3">
          <a href="mailto:info@fundacionpiponavarro.org" class="flex items-center gap-2.5 text-sm text-neutral-400 hover:text-brand-orange transition-colors">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            info@fundacionpiponavarro.org
          </a>
          <a href="tel:+50760000000" class="flex items-center gap-2.5 text-sm text-neutral-400 hover:text-brand-orange transition-colors">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 6 6l1.27-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            +507 6000-0000
          </a>
          <span class="flex items-center gap-2.5 text-sm text-neutral-500">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            {t('contact.address_value')}
          </span>
        </div>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-neutral-600">
        © {year} Fundación Pipo Navarro. {t('footer.rights')}
      </p>
      <p class="text-xs text-neutral-700">
        {lang === 'es'
          ? 'Hecho con ♪ en Panamá'
          : 'Made with ♪ in Panama'}
      </p>
    </div>

  </div>
</footer>
