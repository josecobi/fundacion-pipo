---
import { getCollection } from 'astro:content';
import { Picture, getImage } from 'astro:assets';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Fetch gallery items sorted by order field.
// To add real photos: drop the JPG into src/content/gallery/
// and reference it (e.g. "./photo.jpg") from the corresponding JSON file.
const allItems = await getCollection('gallery');
const items = allItems.sort((a, b) => a.data.order - b.data.order);

// Precompute large variants for the lightbox.
const lightbox = new Map(
  await Promise.all(items.map(async (item) => [
    item.id,
    (await getImage({ src: item.data.image, width: 1600, format: 'webp' })).src,
  ]))
);
---

<section id="galeria" class="relative py-28 bg-warm-section dark:bg-neutral-900/50 overflow-hidden">

  <!-- =============================================
       BACKGROUND DECORATIONS
  ============================================= -->
  <div class="absolute inset-0 pointer-events-none select-none" aria-hidden="true">

    <!-- Faint hibiscus top left -->
    <svg class="absolute top-8 left-6 w-30 opacity-[0.06] dark:opacity-[0.08]" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="60" cy="60" r="14" fill="#E8B84B"/>
      <ellipse cx="60" cy="28" rx="12" ry="22" fill="#D94F3D" opacity="0.7"/>
      <ellipse cx="60" cy="92" rx="12" ry="22" fill="#D94F3D" opacity="0.7"/>
      <ellipse cx="28" cy="60" rx="22" ry="12" fill="#D94F3D" opacity="0.7"/>
      <ellipse cx="92" cy="60" rx="22" ry="12" fill="#D94F3D" opacity="0.7"/>
      <ellipse cx="38" cy="38" rx="12" ry="22" fill="#C85A1A" opacity="0.5" transform="rotate(45 38 38)"/>
      <ellipse cx="82" cy="82" rx="12" ry="22" fill="#C85A1A" opacity="0.5" transform="rotate(45 82 82)"/>
      <ellipse cx="82" cy="38" rx="12" ry="22" fill="#C85A1A" opacity="0.5" transform="rotate(-45 82 38)"/>
      <ellipse cx="38" cy="82" rx="12" ry="22" fill="#C85A1A" opacity="0.5" transform="rotate(-45 38 82)"/>
    </svg>

    <!-- Faint music notes right -->
    <svg class="absolute bottom-16 right-6 w-20 opacity-[0.06] dark:opacity-[0.08]" viewBox="0 0 80 160" fill="none" xmlns="http://www.w3.org/2000/svg">
      <line x1="56" y1="20" x2="56" y2="130" stroke="#C85A1A" stroke-width="4" stroke-linecap="round"/>
      <ellipse cx="44" cy="132" rx="16" ry="10" fill="#C85A1A" transform="rotate(-15 44 132)"/>
    </svg>

  </div>

  <div class="max-w-6xl mx-auto px-6 relative z-10">

    <!-- Section header -->
    <div class="text-center mb-16">
      <div class="flex items-center justify-center gap-3 mb-4">
        <span class="block w-6 h-0.5 bg-brand-orange"></span>
        <span class="text-xs font-semibold tracking-[0.15em] uppercase text-brand-orange">
          {lang === 'es' ? 'Nuestros momentos' : 'Our moments'}
        </span>
        <span class="block w-6 h-0.5 bg-brand-orange"></span>
      </div>
      <h2 class="font-display font-bold text-4xl md:text-5xl text-neutral-900 dark:text-neutral-100 mb-5">
        {t('gallery.title')}
      </h2>
      <p class="text-lg text-neutral-500 dark:text-neutral-400 max-w-lg mx-auto leading-relaxed">
        {t('gallery.subtitle')}
      </p>
    </div>

    <!-- Masonry-style grid -->
    <!-- Featured items span 2 columns on desktop for visual hierarchy -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {items.map((item) => {
        const title = lang === 'es' ? item.data.title_es : item.data.title_en;
        const alt   = lang === 'es' ? item.data.alt_es   : item.data.alt_en;
        const isFeatured = item.data.featured;

        return (
          <div
            class={`
              group relative overflow-hidden rounded-2xl cursor-pointer
              ${isFeatured ? 'sm:col-span-2 lg:col-span-1 lg:row-span-1' : ''}
            `}
            data-lightbox-trigger
            data-src={lightbox.get(item.id)}
            data-title={title}
            data-alt={alt}
          >
            <!-- Image -->
            <Picture
              src={item.data.image}
              widths={[400, 800]}
              sizes="(min-width:1024px) 400px, (min-width:640px) 50vw, 100vw"
              formats={['avif', 'webp']}
              alt={alt}
              class="w-full h-72 sm:h-80 object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />

            <!-- Overlay -->
            <div class="absolute inset-0 bg-linear-to-t from-black/70 via-black/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-5">
              <p class="text-white font-display font-bold text-lg leading-tight">
                {title}
              </p>
              <div class="flex items-center gap-1.5 mt-2">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" opacity="0.7">
                  <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
                <span class="text-white/70 text-xs">
                  {lang === 'es' ? 'Ver imagen' : 'View image'}
                </span>
              </div>
            </div>

            <!-- Featured indicator -->
            {isFeatured && (
              <div class="absolute top-3 left-3 w-2 h-2 rounded-full bg-brand-gold shadow-lg"></div>
            )}
          </div>
        );
      })}
    </div>

  </div>

  <!-- =============================================
       LIGHTBOX
       Pure JS, no external library needed.
       Opens when any gallery item is clicked.
  ============================================= -->
  <div
    id="lightbox"
    class="fixed inset-0 z-200 hidden items-center justify-center bg-black/90 backdrop-blur-sm p-4"
    aria-modal="true"
    role="dialog"
  >
    <!-- Close button -->
    <button
      id="lightbox-close"
      aria-label="Close"
      class="absolute top-4 right-4 w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <!-- Image container -->
    <div class="relative max-w-4xl w-full flex flex-col items-center gap-4">
      <img
        id="lightbox-img"
        src=""
        alt=""
        class="max-h-[80vh] w-auto rounded-xl shadow-2xl object-contain"
      />
      <p
        id="lightbox-title"
        class="text-white/80 text-sm font-medium text-center"
      ></p>
    </div>
  </div>

</section>

<script>
  // =============================================
  // LIGHTBOX LOGIC
  // Simple, readable, no dependencies.
  // =============================================

  const lightbox      = document.getElementById('lightbox') as HTMLElement;
  const lightboxImg   = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxTitle = document.getElementById('lightbox-title') as HTMLElement;
  const closeBtn      = document.getElementById('lightbox-close') as HTMLButtonElement;

  function openLightbox(src: string, title: string, alt: string) {
    lightboxImg.src = src;
    lightboxImg.alt = alt;
    lightboxTitle.textContent = title;
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    lightboxImg.src = '';
    document.body.style.overflow = '';
  }

  // Wire up all gallery trigger cards
  document.querySelectorAll('[data-lightbox-trigger]').forEach((el) => {
    el.addEventListener('click', () => {
      const src   = el.getAttribute('data-src')   ?? '';
      const title = el.getAttribute('data-title') ?? '';
      const alt   = el.getAttribute('data-alt')   ?? '';
      openLightbox(src, title, alt);
    });
  });

  // Close on button click
  closeBtn?.addEventListener('click', closeLightbox);

  // Close on backdrop click (clicking outside the image)
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>
