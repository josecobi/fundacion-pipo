            <path d="M278.311,233.792c-8.3-8.302-19.337-12.873-31.077-12.873c-11.74,0-22.775,4.571-31.077,12.873c-8.302,8.3-12.873,19.337-12.873,31.077c0,11.74,4.571,22.776,12.873,31.077c8.3,8.302,19.337,12.873,31.077,12.873c11.739,0,22.776-4.571,31.077-12.873c8.302-8.3,12.873-19.337,12.873-31.077C291.184,253.13,286.613,242.093,278.311,233.792z M267.558,285.192c-5.428,5.428-12.646,8.418-20.323,8.418s-14.895-2.99-20.323-8.418c-5.428-5.428-8.418-12.646-8.418-20.323c0-7.677,2.99-14.895,8.418-20.323c5.428-5.428,12.646-8.418,20.323-8.418s14.895,2.99,20.323,8.418s8.418,12.646,8.418,20.323C275.976,272.546,272.986,279.764,267.558,285.192z"/>
            <path d="M260.403,109.615c-3.387,0.147-6.797,0.437-10.131,0.863c-4.166,0.531-7.024,4.329-6.58,8.505c0.818,7.685,8.179,6.623,8.505,6.58c2.916-0.372,5.898-0.626,8.863-0.754c4.195-0.182,7.45-3.73,7.268-7.925S264.611,109.442,260.403,109.615z"/>
            <path d="M193.779,405.946l-12.058-12.058l10.128-10.128c2.97-2.97,2.97-7.784,0-10.753c-2.97-2.97-7.784-2.97-10.753,0l-10.127,10.128l-15.623-15.623l22.773-22.773c2.97-2.97,2.97-7.784,0-10.753c-2.97-2.97-7.784-2.97-10.753,0l-22.773,22.773l-15.623-15.623l35.056-35.058c2.97-2.97,2.97-7.784,0-10.753c-2.97-2.97-7.784-2.97-10.753,0l-35.057,35.058l-12.058-12.058c-4.331-4.331-10.091-6.717-16.217-6.717c-6.126,0-11.884,2.386-16.216,6.717s-6.717,10.091-6.717,16.217c0,6.126,2.386,11.885,6.717,16.216l87.621,87.621c4.331,4.331,10.09,6.717,16.216,6.717c6.126,0,11.885-2.386,16.217-6.717c4.331-4.331,6.717-10.091,6.717-16.217C200.496,416.037,198.111,410.278,193.779,405.946z M183.024,427.626c-1.459,1.459-3.399,2.262-5.463,2.262c-2.063,0-4.004-0.803-5.463-2.262l-87.621-87.622c-1.459-1.459-2.263-3.398-2.263-5.462c0-2.064,0.803-4.004,2.263-5.463c1.459-1.459,3.398-2.263,5.462-2.263c2.063,0,4.004,0.804,5.463,2.263l87.621,87.621c1.46,1.459,2.264,3.399,2.264,5.463C185.287,424.226,184.483,426.167,183.024,427.626z"/>
            <path d="M462.52,36.853l-4.439-4.439c-1.578-1.578-4.158-1.578-5.735,0l-4.439,4.439c-1.578,1.578-1.578,4.158,0,5.735l4.439,4.439c1.578,1.578,4.158,1.578,5.735,0l4.439-4.439C464.097,41.011,464.097,38.431,462.52,36.853z"/>
            <path d="M479.689,54.024l-4.439-4.439c-1.578-1.578-4.158-1.578-5.735,0l-4.439,4.439c-1.578,1.578-1.578,4.158,0,5.735l4.439,4.439c1.578,1.578,4.158,1.578,5.735,0l4.439-4.439C481.267,58.182,481.267,55.601,479.689,54.024z"/>
            <path d="M463.231,70.481l-4.439-4.439c-1.578-1.578-4.158-1.578-5.735,0l-4.439,4.439c-1.578,1.578-1.578,4.158,0,5.735l4.439,4.439c1.578,1.578,4.158,1.578,5.735,0l4.439-4.439C464.809,74.639,464.809,72.058,463.231,70.481z"/>
            <path d="M446.062,53.312l-4.439-4.439c-1.578-1.578-4.158-1.578-5.735,0l-4.439,4.439c-1.578,1.578-1.578,4.158,0,5.735l4.439,4.439c1.578,1.578,4.158,1.578,5.735,0l4.439-4.439C447.639,57.47,447.639,54.89,446.062,53.312z"/>
            <path d="M303.604,208.5c-15.035-15.035-35.054-23.315-56.369-23.315c-21.315,0-41.334,8.28-56.37,23.316c-31.082,31.082-31.082,81.655,0,112.737c15.036,15.036,35.054,23.316,56.37,23.316c21.314,0,41.333-8.28,56.369-23.316C334.686,290.156,334.686,239.582,303.604,208.5z M292.851,310.484c-12.163,12.162-28.363,18.861-45.616,18.861s-33.452-6.699-45.616-18.861c-25.153-25.152-25.153-66.077,0-91.23c12.162-12.162,28.363-18.861,45.616-18.861s33.452,6.699,45.616,18.86C318.004,244.406,318.004,285.331,292.851,310.484z"/>
          </svg>
          <span class="text-sm font-semibold text-warm-text dark:text-neutral-300">
            {lang === 'es' ? 'Guitarra' : 'Guitar'}
          </span>
        </div>

        <!-- Instrument card: Piano -->
        <div class="bg-warm-card dark:bg-neutral-900 border border-warm-border dark:border-neutral-800 rounded-2xl p-6 flex flex-col items-center gap-3 hover:border-brand-green dark:hover:border-brand-green hover:shadow-lg transition-all duration-300">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="2" y="6" width="20" height="14" rx="2" stroke="#1A7A4A" stroke-width="1.5" fill="none"/>
            <line x1="7"  y1="6" x2="7"  y2="14" stroke="#1A7A4A" stroke-width="1.5"/>
            <line x1="12" y1="6" x2="12" y2="14" stroke="#1A7A4A" stroke-width="1.5"/>
            <line x1="17" y1="6" x2="17" y2="14" stroke="#1A7A4A" stroke-width="1.5"/>
            <rect x="5"  y="6" width="3" height="8" rx="1" fill="#1A7A4A" opacity="0.6"/>
            <rect x="10" y="6" width="3" height="8" rx="1" fill="#1A7A4A" opacity="0.6"/>
            <rect x="15" y="6" width="3" height="8" rx="1" fill="#1A7A4A" opacity="0.6"/>
          </svg>
          <span class="text-sm font-semibold text-warm-text dark:text-neutral-300">
            {lang === 'es' ? 'Piano / Teclado' : 'Piano / Keyboard'}
          </span>
          <span class="text-xs text-warm-muted dark:text-neutral-500 text-center leading-snug">
            {lang === 'es' ? 'Solo portátiles · no pianos de cola' : 'Portable only · no grand pianos'}
          </span>
        </div>

        <!-- Instrument card: Drums -->
        <div class="bg-warm-card dark:bg-neutral-900 border border-warm-border dark:border-neutral-800 rounded-2xl p-6 flex flex-col items-center gap-3 hover:border-brand-gold dark:hover:border-brand-gold hover:shadow-lg transition-all duration-300">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="12" cy="9" rx="9" ry="4" stroke="#E8B84B" stroke-width="1.5" fill="none"/>
            <path d="M3 9 L3 17 C3 19.2 7 21 12 21 C17 21 21 19.2 21 17 L21 9" stroke="#E8B84B" stroke-width="1.5" fill="none"/>
            <line x1="8"  y1="4" x2="6"  y2="1" stroke="#E8B84B" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="16" y1="4" x2="18" y2="1" stroke="#E8B84B" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span class="text-sm font-semibold text-warm-text dark:text-neutral-300">
            {lang === 'es' ? 'Percusión' : 'Drums'}
          </span>
        </div>

        <!-- Instrument card: Wind -->
