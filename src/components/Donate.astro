---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="donar" class="relative py-28 bg-neutral-50 dark:bg-neutral-900/50 overflow-hidden">

  <!-- =============================================
       BACKGROUND DECORATIONS
  ============================================= -->
  <div class="absolute inset-0 pointer-events-none select-none" aria-hidden="true">

    <!-- Large treble clef faint background -->
    <svg class="absolute -left-8 top-1/2 -translate-y-1/2 w-55 opacity-[0.04] dark:opacity-[0.05]" viewBox="0 0 200 400" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M120 20 C160 20, 180 60, 180 100 C180 160, 120 180, 80 200 C40 220, 20 260, 40 300 C60 340, 120 340, 140 300 C160 260, 140 220, 100 200 L100 360 C100 380, 80 390, 60 380" stroke="#C85A1A" stroke-width="8" stroke-linecap="round" fill="none"/>
      <circle cx="80" cy="370" r="20" stroke="#C85A1A" stroke-width="8" fill="none"/>
    </svg>

    <!-- Tropical leaf bottom right -->
    <svg class="absolute -bottom-10 -right-10 w-65 opacity-[0.05] dark:opacity-[0.07]" viewBox="0 0 260 300" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M220 10 C160 60, 60 160, 20 290 C80 230, 180 130, 220 10Z" fill="#1A7A4A"/>
      <path d="M220 10 C160 80, 70 190, 20 290" stroke="#1A7A4A" stroke-width="2"/>
    </svg>

  </div>

  <div class="max-w-6xl mx-auto px-6 relative z-10">

    <!-- Section header -->
    <div class="text-center mb-20">
      <div class="flex items-center justify-center gap-3 mb-4">
        <span class="block w-6 h-0.5 bg-brand-orange"></span>
        <span class="text-xs font-semibold tracking-[0.15em] uppercase text-brand-orange">
          {lang === 'es' ? 'Haz la diferencia' : 'Make a difference'}
        </span>
        <span class="block w-6 h-0.5 bg-brand-orange"></span>
      </div>
      <h2 class="font-display font-bold text-4xl md:text-5xl text-warm-text dark:text-neutral-100 mb-5">
        {t('donate.title')}
      </h2>
      <p class="text-lg text-warm-muted dark:text-neutral-400 max-w-lg mx-auto leading-relaxed">
        {t('donate.subtitle')}
      </p>
    </div>

    <!-- Main content: steps left, instruments right -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center mb-20">

      <!-- LEFT: 3-step process -->
      <div class="flex flex-col gap-8">

        <!-- Step 1 -->
        <div class="flex gap-6 items-start group">
          <div class="shrink-0 flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-brand-orange flex items-center justify-center shadow-lg shadow-brand-orange/20 group-hover:scale-110 transition-transform duration-200">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 6 6l1.27-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <!-- Connector line -->
            <div class="w-px h-12 bg-warm-border dark:bg-neutral-700 mt-2"></div>
          </div>
          <div class="pt-2 pb-4">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs font-bold tracking-widest uppercase text-brand-orange">
                {lang === 'es' ? 'Paso 1' : 'Step 1'}
              </span>
            </div>
            <h3 class="font-display font-bold text-xl text-warm-text dark:text-neutral-100 mb-2">
              {t('donate.step1_title')}
            </h3>
            <p class="text-warm-muted dark:text-neutral-400 leading-relaxed text-sm">
              {t('donate.step1_text')}
            </p>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="flex gap-6 items-start group">
          <div class="shrink-0 flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-brand-green flex items-center justify-center shadow-lg shadow-brand-green/20 group-hover:scale-110 transition-transform duration-200">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="1" y="3" width="15" height="13" rx="1"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
              </svg>
            </div>
            <div class="w-px h-12 bg-warm-border dark:bg-neutral-700 mt-2"></div>
          </div>
          <div class="pt-2 pb-4">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs font-bold tracking-widest uppercase text-brand-green">
                {lang === 'es' ? 'Paso 2' : 'Step 2'}
              </span>
            </div>
            <h3 class="font-display font-bold text-xl text-warm-text dark:text-neutral-100 mb-2">
              {t('donate.step2_title')}
            </h3>
            <p class="text-warm-muted dark:text-neutral-400 leading-relaxed text-sm">
              {t('donate.step2_text')}
            </p>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="flex gap-6 items-start group">
          <div class="shrink-0">
            <div class="w-12 h-12 rounded-full bg-brand-gold flex items-center justify-center shadow-lg shadow-brand-gold/20 group-hover:scale-110 transition-transform duration-200">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </div>
          </div>
          <div class="pt-2">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs font-bold tracking-widest uppercase text-brand-gold">
                {lang === 'es' ? 'Paso 3' : 'Step 3'}
              </span>
            </div>
            <h3 class="font-display font-bold text-xl text-warm-text dark:text-neutral-100 mb-2">
              {t('donate.step3_title')}
            </h3>
            <p class="text-warm-muted dark:text-neutral-400 leading-relaxed text-sm">
              {t('donate.step3_text')}
            </p>
          </div>
        </div>

        <!-- Shipping note -->
        <div class="flex gap-4 p-4 bg-warm-card dark:bg-neutral-900/60 border border-warm-border dark:border-neutral-800 rounded-xl">
          <div class="shrink-0 w-9 h-9 rounded-lg bg-brand-green/10 dark:bg-brand-green/15 flex items-center justify-center">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1A7A4A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="1" y="3" width="15" height="13" rx="1"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
              <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-warm-text dark:text-neutral-200">{t('donate.shipping_title')}</p>
            <p class="text-xs text-warm-muted dark:text-neutral-400 leading-relaxed mt-0.5">{t('donate.shipping_body')}</p>
          </div>
        </div>

        <!-- CTA button -->
        <div class="pt-4">
          <a
            href="#contacto"
            class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-brand-orange text-white text-sm font-semibold hover:-translate-y-0.5 hover:shadow-lg hover:shadow-brand-orange/25 transition-all duration-150"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
            {t('donate.cta')}
          </a>
        </div>

      </div>

      <!-- RIGHT: Instrument types visual grid -->
      <div class="grid grid-cols-2 gap-4">

        <!-- Instrument card: Guitar -->
        <div class="bg-warm-card dark:bg-neutral-900 border border-warm-border dark:border-neutral-800 rounded-2xl p-6 flex flex-col items-center gap-3 hover:border-brand-orange dark:hover:border-brand-orange hover:shadow-lg transition-all duration-300">
          <svg fill="#C85A1A" width="40" height="40" viewBox="0 0 511.999 511.999" xmlns="http://www.w3.org/2000/svg">
            <path d="M506.999,5.106c-3.542-3.541-8.392-5.348-13.419-4.949l-39.077,3.085c-4.049,0.318-7.861,2.076-10.734,4.949l-4.665,4.665c0,0-5.33-5.979-11.031-0.278c-5.701,5.701,0.278,11.031,0.278,11.031l-5.704,5.704c0,0-5.608-5.701-11.031-0.278c-5.423,5.423,0.278,11.031,0.278,11.031l-5.586,5.586c-3.125,3.125-4.9,7.279-4.998,11.697c0,0-0.434,20.891-0.426,21.173l-61.202,53.619c-16.63-11.064-35.213-18.301-54.86-21.228c-4.152-0.626-8.023,2.246-8.641,6.401c-0.618,4.154,2.247,8.023,6.401,8.641c25.663,3.823,49.342,15.958,68.476,35.093c21.55,21.55,34.384,49.418,36.138,78.47c0.874,14.489-1.046,28.515-5.707,41.69c-4.91,13.877-12.63,26.143-22.945,36.457c-11.428,11.428-26.592,18.41-33.067,21.39c-1.321,0.608-18.273,5.495-19.264,33.709c-1.176,33.471-14.396,64.364-37.027,86.996c-13.374,13.373-29.312,23.349-47.372,29.652c-17.193,6-35.534,8.41-54.516,7.16c-38.232-2.514-75.015-19.629-103.575-48.191c-28.56-28.56-45.675-65.343-48.192-103.572c-1.25-18.981,1.159-37.322,7.16-54.516c6.303-18.06,16.28-33.998,29.653-47.372c22.626-22.626,53.513-35.776,86.969-37.027c0,0,25.984,0.31,32.566-16.842c0.531-1.384,9.434-22.365,22.558-35.49c10.315-10.315,22.581-18.035,36.458-22.945c3.959-1.4,6.032-5.746,4.631-9.705c-1.4-3.959-5.746-6.034-9.705-4.631c-16.031,5.672-30.208,14.597-42.139,26.528c-14.914,14.913-23.386,34.227-25.82,40.329c-0.435,0.705-4.301,6.218-19.315,7.566c-37.228,1.439-71.657,16.159-96.96,41.463c-15.005,15.005-26.194,32.876-33.258,53.114c-6.677,19.133-9.361,39.497-7.976,60.526c2.76,41.911,21.444,82.158,52.614,113.327c31.17,31.17,71.416,49.855,113.326,52.614c3.585,0.236,35.009,1.198,60.527-7.976c20.172-7.253,38.108-18.253,53.114-33.258c25.355-25.355,38.706-59.946,41.474-97.272c1.253-16.895,9.371-19.887,10.424-20.372c7.215-3.321,24.109-11.1,37.46-24.451c11.931-11.93,20.856-26.108,26.528-42.139c5.345-15.106,7.549-31.147,6.551-47.679c-1.417-23.483-9.221-46.244-22.429-66.157l53.631-61.215c0.157,0.004,21.18-0.433,21.18-0.433c4.418-0.098,8.572-1.874,11.696-4.998l5.586-5.586c0,0,5.175,6.134,1